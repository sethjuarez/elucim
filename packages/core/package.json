{
  "name": "@elucim/core",
  "version": "0.8.1",
  "description": "React library for animated math and concept visualizations — 3Blue1Brown-style for the web",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sethjuarez/elucim.git",
    "directory": "packages/core"
  },
  "homepage": "https://elucim.com",
  "bugs": "https://github.com/sethjuarez/elucim/issues",
  "keywords": [
    "react",
    "animation",
    "math",
    "visualization",
    "svg",
    "manim",
    "3blue1brown",
    "image",
    "group",
    "transforms",
    "presentation",
    "latex"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^28.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "katex": "^0.16.33"
  }
}
